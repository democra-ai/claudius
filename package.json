{
  "name": "claude-multiprofile",
  "version": "0.1.9",
  "description": "Run multiple Claude Desktop and Claude Code accounts side by side on macOS, fully isolated.",
  "type": "module",
  "bin": {
    "claude-multiprofile": "./bin/claude-multiprofile.js"
  },
  "main": "./src/cli.js",
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./bin/claude-multiprofile.js",
    "test": "node --test test/unit.test.js",
    "frontend:install": "npm --prefix frontend install",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "anthropic",
    "claude-desktop",
    "claude-code",
    "multi-account",
    "profiles",
    "macos",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/democra-ai/claude-multiprofile.git"
  }
}
